services:
  # ============================================================================
  # PLANE — Project management (Community Edition)
  # ============================================================================
  plane-web:
    image: makeplane/plane-frontend:stable
    container_name: plane-web
    restart: unless-stopped
    depends_on:
      - plane-api
    volumes:
      - ./nginx/spa.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      - devpanel_net
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.plane.rule=Host(`plane.devpanl.dev`)"
      - "traefik.http.routers.plane.entrypoints=websecure"
      - "traefik.http.routers.plane.tls=true"
      - "traefik.http.routers.plane.tls.certresolver=letsencrypt"
      - "traefik.http.routers.plane.priority=1"
      - "traefik.http.services.plane.loadbalancer.server.port=3000"

  plane-admin:
    image: makeplane/plane-admin:stable
    container_name: plane-admin
    restart: unless-stopped
    depends_on:
      - plane-api
    volumes:
      - ./nginx/spa.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      - devpanel_net
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.plane-admin.rule=Host(`plane.devpanl.dev`) && PathPrefix(`/god-mode`)"
      - "traefik.http.routers.plane-admin.entrypoints=websecure"
      - "traefik.http.routers.plane-admin.tls=true"
      - "traefik.http.routers.plane-admin.tls.certresolver=letsencrypt"
      - "traefik.http.routers.plane-admin.priority=20"
      - "traefik.http.services.plane-admin.loadbalancer.server.port=3000"

  plane-space:
    image: makeplane/plane-space:stable
    container_name: plane-space
    restart: unless-stopped
    depends_on:
      - plane-api
    volumes:
      - ./nginx/spa.conf:/etc/nginx/conf.d/default.conf:ro
    networks:
      - devpanel_net
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.plane-space.rule=Host(`plane.devpanl.dev`) && PathPrefix(`/spaces`)"
      - "traefik.http.routers.plane-space.entrypoints=websecure"
      - "traefik.http.routers.plane-space.tls=true"
      - "traefik.http.routers.plane-space.tls.certresolver=letsencrypt"
      - "traefik.http.routers.plane-space.priority=20"
      - "traefik.http.services.plane-space.loadbalancer.server.port=3000"

  plane-live:
    image: makeplane/plane-live:stable
    container_name: plane-live
    restart: unless-stopped
    depends_on:
      - plane-api
      - plane-redis
    environment:
      API_BASE_URL: http://plane-api:8000
      LIVE_SERVER_SECRET_KEY: ${PLANE_SECRET_KEY}
      REDIS_URL: redis://plane-redis:6379
    networks:
      - devpanel_net
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.plane-live.rule=Host(`plane.devpanl.dev`) && PathPrefix(`/live`)"
      - "traefik.http.routers.plane-live.entrypoints=websecure"
      - "traefik.http.routers.plane-live.tls=true"
      - "traefik.http.routers.plane-live.tls.certresolver=letsencrypt"
      - "traefik.http.routers.plane-live.priority=20"
      - "traefik.http.services.plane-live.loadbalancer.server.port=3000"

  plane-api:
    image: makeplane/plane-backend:stable
    container_name: plane-api
    restart: unless-stopped
    command: ./bin/docker-entrypoint-api.sh
    environment:
      DATABASE_URL: postgresql://plane:${PLANE_DB_PASSWORD}@plane-db:5432/plane
      REDIS_URL: redis://plane-redis:6379
      AMQP_URL: redis://plane-redis:6379/0
      SECRET_KEY: ${PLANE_SECRET_KEY}
      WEB_URL: https://plane.devpanl.dev
      CORS_ALLOWED_ORIGINS: https://plane.devpanl.dev
      GUNICORN_WORKERS: 2
      ENABLE_EMAIL_PASSWORD: "1"
      ENABLE_MAGIC_LINK_LOGIN: "0"
      ENABLE_SIGNUP: "1"
      AWS_ACCESS_KEY_ID: ${PLANE_MINIO_ROOT_USER:-plane}
      AWS_SECRET_ACCESS_KEY: ${PLANE_MINIO_ROOT_PASSWORD:-planesecret}
      AWS_S3_BUCKET_NAME: plane-uploads
      AWS_S3_ENDPOINT_URL: https://minio.devpanl.dev
      AWS_REGION: us-east-1
      FILE_SIZE_LIMIT: "10485760"
    depends_on:
      plane-db:
        condition: service_healthy
      plane-migrator:
        condition: service_completed_successfully
    networks:
      - devpanel_net
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.plane-api.rule=Host(`plane.devpanl.dev`) && (PathPrefix(`/api`) || PathPrefix(`/auth`))"
      - "traefik.http.routers.plane-api.entrypoints=websecure"
      - "traefik.http.routers.plane-api.tls=true"
      - "traefik.http.routers.plane-api.tls.certresolver=letsencrypt"
      - "traefik.http.routers.plane-api.priority=10"
      - "traefik.http.routers.plane-api.middlewares=plane-api-nocache"
      - "traefik.http.middlewares.plane-api-nocache.headers.customresponseheaders.Cache-Control=no-store, no-cache, must-revalidate"
      - "traefik.http.services.plane-api.loadbalancer.server.port=8000"

  plane-worker:
    image: makeplane/plane-backend:stable
    container_name: plane-worker
    restart: unless-stopped
    command: ./bin/docker-entrypoint-worker.sh
    environment:
      DATABASE_URL: postgresql://plane:${PLANE_DB_PASSWORD}@plane-db:5432/plane
      REDIS_URL: redis://plane-redis:6379
      AMQP_URL: redis://plane-redis:6379/0
      SECRET_KEY: ${PLANE_SECRET_KEY}
      WEB_URL: https://plane.devpanl.dev
      AWS_ACCESS_KEY_ID: ${PLANE_MINIO_ROOT_USER:-plane}
      AWS_SECRET_ACCESS_KEY: ${PLANE_MINIO_ROOT_PASSWORD:-planesecret}
      AWS_S3_BUCKET_NAME: plane-uploads
      AWS_S3_ENDPOINT_URL: https://minio.devpanl.dev
      AWS_REGION: us-east-1
    depends_on:
      - plane-api
    networks:
      - devpanel_net

  plane-beat:
    image: makeplane/plane-backend:stable
    container_name: plane-beat
    restart: unless-stopped
    command: ./bin/docker-entrypoint-beat.sh
    environment:
      DATABASE_URL: postgresql://plane:${PLANE_DB_PASSWORD}@plane-db:5432/plane
      REDIS_URL: redis://plane-redis:6379
      AMQP_URL: redis://plane-redis:6379/0
      SECRET_KEY: ${PLANE_SECRET_KEY}
    depends_on:
      - plane-api
    networks:
      - devpanel_net

  plane-migrator:
    image: makeplane/plane-backend:stable
    container_name: plane-migrator
    restart: "no"
    command: ./bin/docker-entrypoint-migrator.sh
    environment:
      DATABASE_URL: postgresql://plane:${PLANE_DB_PASSWORD}@plane-db:5432/plane
      REDIS_URL: redis://plane-redis:6379
      AMQP_URL: redis://plane-redis:6379/0
      SECRET_KEY: ${PLANE_SECRET_KEY}
    depends_on:
      plane-db:
        condition: service_healthy
    networks:
      - devpanel_net

  # Plane has its own PostgreSQL (separate from AFFiNE)
  plane-db:
    image: postgres:15.7-alpine
    container_name: plane-db
    restart: unless-stopped
    environment:
      POSTGRES_USER: plane
      POSTGRES_PASSWORD: ${PLANE_DB_PASSWORD}
      POSTGRES_DB: plane
    volumes:
      - plane-pgdata:/var/lib/postgresql/data
    networks:
      - devpanel_net
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U plane"]
      interval: 10s
      timeout: 3s
      retries: 3

  # Plane needs its own Redis (BullMQ uses noeviction, Plane needs allkeys-lru)
  plane-redis:
    image: redis:7-alpine
    container_name: plane-redis
    restart: unless-stopped
    command: redis-server --appendonly yes --maxmemory 128mb --maxmemory-policy allkeys-lru
    volumes:
      - plane-redisdata:/data
    networks:
      - devpanel_net
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 3s
      retries: 3

  # MinIO — S3-compatible storage for file uploads
  plane-minio:
    image: minio/minio:latest
    container_name: plane-minio
    restart: unless-stopped
    command: server /data --console-address ":9001"
    environment:
      MINIO_ROOT_USER: ${PLANE_MINIO_ROOT_USER:-plane}
      MINIO_ROOT_PASSWORD: ${PLANE_MINIO_ROOT_PASSWORD:-planesecret}
      MINIO_BROWSER_REDIRECT_URL: https://minio-console.devpanl.dev
      MINIO_API_CORS_ALLOW_ORIGIN: https://plane.devpanl.dev
    volumes:
      - plane-minio-data:/data
    networks:
      - devpanel_net
    labels:
      - "traefik.enable=true"
      # S3 API
      - "traefik.http.routers.plane-minio.rule=Host(`minio.devpanl.dev`)"
      - "traefik.http.routers.plane-minio.entrypoints=websecure"
      - "traefik.http.routers.plane-minio.tls=true"
      - "traefik.http.routers.plane-minio.tls.certresolver=letsencrypt"
      - "traefik.http.routers.plane-minio.service=plane-minio"
      - "traefik.http.services.plane-minio.loadbalancer.server.port=9000"
    healthcheck:
      test: ["CMD", "mc", "ready", "local"]
      interval: 10s
      timeout: 3s
      retries: 3

  # Create the default bucket on startup
  plane-minio-init:
    image: minio/mc:latest
    container_name: plane-minio-init
    restart: "no"
    depends_on:
      plane-minio:
        condition: service_healthy
    entrypoint: >
      /bin/sh -c "
      mc alias set planeminio http://plane-minio:9000 $${MINIO_ROOT_USER} $${MINIO_ROOT_PASSWORD} &&
      mc mb planeminio/plane-uploads --ignore-existing &&
      mc anonymous set download planeminio/plane-uploads
      "
    environment:
      MINIO_ROOT_USER: ${PLANE_MINIO_ROOT_USER:-plane}
      MINIO_ROOT_PASSWORD: ${PLANE_MINIO_ROOT_PASSWORD:-planesecret}
    networks:
      - devpanel_net

volumes:
  plane-pgdata:
  plane-redisdata:
  plane-minio-data:

networks:
  devpanel_net:
    external: true
