[Unit]
Description=DevPanel Agent Worker (runs on agents node, spawns claude -p)
After=network-online.target
Wants=network-online.target
StartLimitIntervalSec=60
StartLimitBurst=5

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/home/deploy/projects/dev-panel
ExecStart=/usr/bin/node src/worker/index.js
Restart=always
RestartSec=5

# Runtime
Environment=NODE_ENV=production
Environment=PROJECT_ROOT=/home/deploy/projects/dev-panel
Environment=DEVPANEL_STORAGE=/home/deploy/projects/dev-panel/storage
# Memory budget: each builder spawns a full MCP graph (devpanel + plane +
# github + affine x3 + playwright + glitchtip ≈ 1-1.5 GB) on top of the
# main agent process. Host went 4 GB → 8 GB on 2026-05-08 after OOMs at
# concurrency=3 on the smaller VM. At 8 GB we have headroom for 2 builders
# alongside Shelly (~1 GB) and the worker itself; revisit at 3 only after
# 1 week of stable Phase A-1 canary runs.
Environment=WORKER_CONCURRENCY=2
Environment=WORKER_API_PORT=3099
Environment=PATH=/home/deploy/.bun/bin:/home/deploy/.local/bin:/home/deploy/.npm-global/bin:/usr/local/bin:/usr/bin:/bin

# Cross-node connectivity (services node exposes redis + postgres on LAN)
Environment=REDIS_HOST=10.0.0.2
Environment=REDIS_PORT=6379
Environment=PG_HOST=10.0.0.2
Environment=PG_PORT=5432
Environment=PG_USER=affine
Environment=PG_DATABASE=agent_memory
Environment=AGENT_MEMORY_NAMESPACE=dev-panel
Environment=VOYAGE_MODEL=voyage-code-3
Environment=WORKER_EVENTS_URL=https://devpanl.dev/api/admin/events/publish
# DEVPA-180: dispatcher resolves Plane project_id → local_path via the
# services-side /api/admin/projects/by-plane-id/:id route. Without this,
# enqueueWorkflowStart falls back to the agents-host SQLite which is empty.
Environment=API_BASE=https://devpanl.dev

# Plane REST config (non-secrets). PLANE_API_KEY is in .env.agent.
Environment=PLANE_BASE_URL=https://plane.devpanl.dev
Environment=PLANE_WORKSPACE_SLUG=devpanl
Environment=PLANE_PROJECT_ID=d2522fed-e3f2-4eeb-9077-6445261752c1

# Backlog puller defaults — flip BACKLOG_PULL_ENABLED to "true" to start the
# continuous Plane-Todo → workflow loop. LABEL gate keeps only items you've
# explicitly tagged "agent-ready" in-scope for the agent team.
Environment=BACKLOG_PULL_ENABLED=true
Environment=BACKLOG_PULL_LABEL=agent-ready
Environment=BACKLOG_PULL_STATE_GROUPS=unstarted
Environment=BACKLOG_PULL_MAX_PER_TICK=3
Environment=BACKLOG_PULL_INTERVAL_MS=900000

# Secrets come from a hand-managed file on the agents node (not CI-deployed):
#   /home/deploy/projects/dev-panel/.env.agent
# Required keys: PG_PASSWORD, VOYAGE_API_KEY, ADMIN_API_KEY, GITHUB_TOKEN,
#                TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID, PLANE_API_KEY
EnvironmentFile=-/home/deploy/projects/dev-panel/.env.agent

StandardOutput=journal
StandardError=journal
SyslogIdentifier=devpanel-worker

[Install]
WantedBy=multi-user.target
