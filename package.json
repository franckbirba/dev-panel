{
  "name": "dev-panel",
  "version": "2.1.0",
  "description": "Plug & play bug/feature reporting panel with SQLite storage and GitHub sync",
  "type": "module",
  "main": "./src/server/index.js",
  "exports": {
    ".": "./src/server/index.js",
    "./react": "./src/react/index.js",
    "./mcp": "./src/mcp/server.js"
  },
  "bin": {
    "dev-panel": "./bin/dev-panel.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build:dashboard-legacy": "vite build",
    "build:chat": "cd apps/chat && npm install --no-audit --no-fund --silent && npm run build && cd ../.. && rm -rf dist/dashboard && mv apps/chat/out dist/dashboard",
    "build:dashboard": "npm run build:chat && npm run build:dashboard-legacy",
    "build:widget": "vite build --config vite.widget.config.js",
    "build": "npm run build:dashboard && npm run build:widget",
    "dev:dashboard": "vite --config vite.config.js",
    "dev:chat": "cd apps/chat && npm run dev"
  },
  "keywords": [
    "bug-tracking",
    "feature-requests",
    "github",
    "sqlite",
    "dev-tools",
    "issue-tracking",
    "developer-tools"
  ],
  "author": "Franck Birba",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/franckbirba/dev-panel.git"
  },
  "bugs": {
    "url": "https://github.com/franckbirba/dev-panel/issues"
  },
  "homepage": "https://github.com/franckbirba/dev-panel#readme",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@ai-sdk/mcp": "^1.0.41",
    "@ai-sdk/openai": "^3.0.63",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@modelcontextprotocol/server-github": "^2025.4.8",
    "affine-mcp-server": "^1.13.0",
    "ai": "^6.0.177",
    "arctic": "^3.7.0",
    "better-sqlite3": "^11.0.0",
    "bullmq": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^12.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.3.0",
    "multer": "^1.4.5-lts.1",
    "octokit": "^3.0.0",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react-dom": "^19.2.5",
    "socket.io": "^4.8.3",
    "socket.io-client": "^4.8.3",
    "tailwind-merge": "^3.5.0",
    "wouter": "^3.9.0",
    "yaml": "^2.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.2",
    "react": "^19.2.5",
    "supertest": "^7.2.2",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.6"
  },
  "files": [
    "bin",
    "src",
    "templates",
    "README.md"
  ]
}
