{
  "name": "dev-panel",
  "version": "2.0.0",
  "description": "Plug & play bug/feature reporting panel with SQLite storage and GitHub sync",
  "type": "module",
  "main": "./src/server/index.js",
  "exports": {
    ".": "./src/server/index.js",
    "./react": "./src/react/index.js",
    "./mcp": "./src/mcp/server.js"
  },
  "bin": {
    "dev-panel": "./bin/dev-panel.js"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "build": "vite build",
    "dev:dashboard": "vite --config vite.config.js"
  },
  "keywords": [
    "bug-tracking",
    "feature-requests",
    "github",
    "sqlite",
    "dev-tools",
    "issue-tracking",
    "developer-tools"
  ],
  "author": "Franck Birba",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/franckbirba/dev-panel.git"
  },
  "bugs": {
    "url": "https://github.com/franckbirba/dev-panel/issues"
  },
  "homepage": "https://github.com/franckbirba/dev-panel#readme",
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^11.0.0",
    "bullmq": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "commander": "^12.0.0",
    "cors": "^2.8.5",
    "express": "^4.18.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "html2canvas": "^1.4.1",
    "ioredis": "^5.3.0",
    "multer": "^1.4.5-lts.1",
    "octokit": "^3.0.0",
    "pg": "^8.20.0",
    "radix-ui": "^1.4.3",
    "react-dom": "^19.2.5",
    "tailwind-merge": "^3.5.0",
    "wouter": "^3.9.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^19.2.5",
    "tailwindcss": "^4.2.2",
    "vite": "^8.0.8",
    "vitest": "^4.1.4"
  },
  "files": [
    "bin",
    "src",
    "templates",
    "README.md"
  ]
