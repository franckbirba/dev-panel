# dev-panel production environment variables
# Copy to .env and fill in values

# GitHub token for repo sync (required)
GITHUB_TOKEN=ghp_your_token_here

# Admin API key for /api/projects endpoints (required in production)
# Generate with: node -e "console.log('admin_' + require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=admin_your_key_here

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=*

# Node environment
NODE_ENV=production

# Penpot Configuration
# Generate secret key with: openssl rand -hex 32
PENPOT_SECRET_KEY=your_secret_key_here

# Penpot SMTP (optional, for email notifications)
PENPOT_SMTP_HOST=smtp.example.com
PENPOT_SMTP_PORT=587
PENPOT_SMTP_TLS=true
PENPOT_SMTP_SSL=false
PENPOT_SMTP_USERNAME=your_smtp_username
PENPOT_SMTP_PASSWORD=your_smtp_password
PENPOT_SMTP_FROM=no-reply@devpanl.dev
PENPOT_SMTP_REPLY_TO=no-reply@devpanl.dev

# AFFiNE Configuration
# Generate server ID with: node -e "console.log(require('crypto').randomUUID())"
AFFINE_SERVER_ID=your_server_uuid_here
AFFINE_DB_USERNAME=affine
AFFINE_DB_PASSWORD=your_secure_password_here
AFFINE_DB_NAME=affine

# AFFiNE SMTP (optional, for email notifications)
AFFINE_SMTP_HOST=smtp.example.com
AFFINE_SMTP_PORT=587
AFFINE_SMTP_USER=your_smtp_username
AFFINE_SMTP_PASSWORD=your_smtp_password
AFFINE_SMTP_SENDER=no-reply@devpanl.dev
AFFINE_SMTP_IGNORE_TLS=false

# BullMQ Configuration
# BullMQ Board auth (format: username:hashed_password)
# Generate with: htpasswd -nb admin yourpassword
# Or online: https://hostingcanada.org/htpasswd-generator/
BULLMQ_BOARD_AUTH=admin:$$apr1$$xyz$$hash_here

# oauth2-proxy — Google SSO gate for traefik dashboard, bull-board, storybook
# Create OAuth 2.0 Web Application credentials at:
#   https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://auth.devpanl.dev/oauth2/callback
OAUTH2_PROXY_CLIENT_ID=
OAUTH2_PROXY_CLIENT_SECRET=
# Generate with: openssl rand -base64 32 | tr -- '+/' '-_' | tr -d '=' | head -c 32
OAUTH2_PROXY_COOKIE_SECRET=

# AFFiNE MCP Configuration
# Generate API token in AFFiNE: Settings > API Tokens > Generate
AFFINE_MCP_TOKEN=ut_your_token_here
AFFINE_MCP_WORKSPACE_ID=your_workspace_id_here

# Agent Memory (shared pgvector in AFFiNE postgres)
AGENT_MEMORY_DB_URL=postgresql://${AFFINE_DB_USERNAME}:${AFFINE_DB_PASSWORD}@affine-postgres:5432/${AFFINE_DB_NAME:-affine}

# --- Memory layer ---
PG_HOST=devpanel-postgres
PG_PORT=5432
PG_USER=affine
PG_PASSWORD=
PG_DATABASE=agent_memory
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-code-3

# --- Agents ---
AGENT_MEMORY_NAMESPACE=dev-panel
DEPLOY_ALLOWED_REQUESTERS=franck,cron:nightly
DEPLOY_CRON=0 3 * * *
DEPLOY_TIMEZONE=Europe/Paris

# --- Worker <-> server IPC ---
WORKER_EVENTS_URL=http://localhost:3030/api/admin/events/publish
ADMIN_API_KEY=

# --- Plane integration (Spec 2 workflow engine) ---
# Workspace-level credentials. Per-project identifiers (Plane project_id,
# cycle_id, work_item_id) are NOT env vars — devpanl is multi-project and
# resolves them per import. The plane_close_cycle MCP tool takes project_id
# as a parameter; future work resolves it from the devpanl projects table.
PLANE_BASE_URL=https://plane.devpanl.dev
PLANE_WORKSPACE_SLUG=devpanl
PLANE_API_TOKEN=

# --- GlitchTip — error tracking (DEVPA-168 infra + DEVPA-169 bridge) ---
# Self-hosted GlitchTip stack at glitchtip.devpanl.dev. Profile `glitchtip`
# is OPTED OUT of CI deploys (CLAUDE.md "Deploy isolation rule") — bootstrap
# manually on the services VPS:
#   docker compose --profile glitchtip up -d

# Django SECRET_KEY for GlitchTip web + worker. Generate with:
#   openssl rand -base64 50 | tr -d '\n'
GLITCHTIP_SECRET_KEY=

# Postgres password for the dedicated glitchtip-db container.
# IMPORTANT: like Plane (cf. CLAUDE.md "Postgres stored password drift"),
# this only initialises the DB role on first volume write. Changing it
# after the volume exists has no effect — the running DB still accepts the
# original. To rotate: docker exec glitchtip-db psql -U glitchtip -d glitchtip
#   -c "ALTER USER glitchtip WITH PASSWORD '<new>';"
GLITCHTIP_DB_PASSWORD=

# Public domain. DNS A record glitchtip.devpanl.dev → 77.42.46.87.
GLITCHTIP_DOMAIN=glitchtip.devpanl.dev

# Outbound email config (for invitations + alert notifications).
# Defaults are empty placeholders; in dev `consolemail://` prints to stdout.
GLITCHTIP_DEFAULT_FROM_EMAIL=glitchtip@devpanl.dev
GLITCHTIP_EMAIL_URL=consolemail://

# `False` = invitation-only (recommended). `True` opens the registration page.
GLITCHTIP_ENABLE_USER_REGISTRATION=False

# HMAC secret shared between GlitchTip (custom webhook signing) and the
# devpanl bridge endpoint /api/webhooks/glitchtip/:projectId. Generate with:
#   openssl rand -hex 32
# Required in production; in development the route accepts unsigned events
# when this is empty (NODE_ENV != 'production').
GLITCHTIP_BRIDGE_HMAC_SECRET=
